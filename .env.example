# ── Camera sources ──────────────────────────────────────
# Integer = webcam index. String rtsp://... = IP camera URL.
# Camera 0 = Logitech (USB external — typically device index 0 on Windows)
CAMERA_0_SOURCE=0
CAMERA_0_NAME=Logitech
# Camera 1 = Laptop built-in webcam (typically device index 1 on Windows)
CAMERA_1_SOURCE=1
CAMERA_1_NAME=Laptop Webcam
# Windows: dshow | Linux/Mac: leave empty
CAMERA_BACKEND=dshow
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# ── Detection ────────────────────────────────────────────
MODEL_PATH=models/yolo11n.pt
CONFIDENCE_THRESHOLD=0.75
INFERENCE_SIZE=640
# Set to "cuda" for GPU, "cpu" to force CPU
DEVICE=cpu

# ── API security ──────────────────────────────────────────
API_KEY=change_me_to_something_secret

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Performance ───────────────────────────────────────────
# Skip inference every N frames (1 = process every frame)
FRAME_SKIP=1
# JPEG quality for WebSocket streaming (1-100)
JPEG_QUALITY=75

# ── Camera enable / disable ───────────────────────────────
# Set false to skip a camera entirely at startup.
# Also toggleable at runtime: POST /api/cameras/cam0/enable|disable
CAMERA_0_ENABLED=true
CAMERA_1_ENABLED=true

# ── Windows device watchdog ───────────────────────────────
# Exact names from: Get-PnpDevice -Status OK | Select FriendlyName
ENABLE_DEVICE_WATCHDOG=true
CAMERA_0_DEVICE_NAME=HD Pro Webcam C920
CAMERA_1_DEVICE_NAME=Integrated Camera